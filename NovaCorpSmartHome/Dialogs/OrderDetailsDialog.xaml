<Window x:Class="NovaCorpSmartHome.Dialogs.OrderDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали заказа - Новус"
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Информация о заказе №{Binding OrderId}" 
                   FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Данные клиента -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="👤 Клиент" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ClientName}" FontSize="14" Foreground="#334155"/>
                        <TextBlock Text="{Binding ClientPhone}" FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding ClientAddress}" FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Состав заказа -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📦 Состав заказа" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding OrderItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="13" Foreground="#334155" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Комментарий менеджера -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="💬 Комментарий менеджера" FontWeight="Bold" Foreground="#D97706" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ManagerComment}" 
                                   FontSize="13" 
                                   Foreground="#334155" 
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- НОВЫЙ БЛОК: Информация об установке (только для истории) -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding IsInstallationInfoVisible}">
                    <StackPanel>
                        <TextBlock Text="🛠️ Отчет об установке" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,5"/>

                        <!-- Комментарий установщика -->
                        <TextBlock Text="Комментарий установщика:" FontSize="12" Foreground="#64748B" Margin="0,5,0,2"/>
                        <TextBlock Text="{Binding InstallerComment}" 
                                   FontSize="13" 
                                   Foreground="#334155" 
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <!-- Файл -->
                        <TextBlock Text="Прикрепленный файл:" FontSize="12" Foreground="#64748B" Margin="0,5,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="txtFileNameDisplay" 
                                       Text="{Binding FileName}" 
                                       FontSize="13" 
                                       Foreground="#3B82F6" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       ToolTip="{Binding FilePath}"/>

                            <Button Grid.Column="1" Content="Открыть файл" Width="100" Height="30"
                                    Background="#3B82F6" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" Click="btnOpenFile_Click"
                                    Visibility="{Binding HasFile}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="2" Content="Закрыть" HorizontalAlignment="Right" 
                Width="100" Height="40" Margin="0,20,0,0"
                Background="#3B82F6" Foreground="White" BorderThickness="0"
                Cursor="Hand" Click="btnClose_Click"/>
    </Grid>
</Window>
<Window x:Class="NovaCorpSmartHome.Dialogs.CompleteWorkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершение работ - Новус"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Подтверждение завершения монтажа" 
                   FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <!-- Комментарий -->
            <TextBlock Text="Комментарий к работе:" FontSize="13" Foreground="#334155" Margin="0,0,0,5"/>
            <TextBox x:Name="txtComment" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Background="White" BorderBrush="#CBD5E1" Padding="5" FontSize="13"/>

            <!-- Файл -->
            <TextBlock Text="Прикрепить файл (Акт, фото, схема):" FontSize="13" Foreground="#334155" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtFilePath" Text="Файл не выбран" 
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0"/>
                <Button Grid.Column="1" Content="Выбрать..." Width="100" Height="30"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="btnSelectFile_Click"/>
            </Grid>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="40" Margin="0,0,10,0"
                    Background="#E2E8F0" Foreground="#334155" BorderThickness="0"
                    Cursor="Hand" Click="btnCancel_Click"/>
            <Button Content="Подтвердить" Width="120" Height="40"
                    Background="#10B981" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Application x:Class="NovaCorpSmartHome.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NovaCorpSmartHome"
             StartupUri="MainWindow.xaml">
    
    <Application.Resources>
        <!-- ЦВЕТА -->
        <Color x:Key="AccentColorCode">#3B82F6</Color>
        <Color x:Key="SecondaryColorCode">#10B981</Color>
        <Color x:Key="ErrorColorCode">#EF4444</Color>
        <Color x:Key="WarningColorCode">#F59E0B</Color>

        <!-- КИСТИ -->
        <SolidColorBrush x:Key="AccentColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#10B981"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>

        <SolidColorBrush x:Key="BgColor" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PanelColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E2E8F0"/>

        <SolidColorBrush x:Key="StatusGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="StatusYellow" Color="#F59E0B"/>
        <SolidColorBrush x:Key="StatusRed" Color="#EF4444"/>

        <!-- ГРАДИЕНТЫ -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3B82F6" Offset="0.0"/>
            <GradientStop Color="#2563EB" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0.0"/>
            <GradientStop Color="#F8FAFC" Offset="1.0"/>
        </LinearGradientBrush>
        
        <Style TargetType="TextBlock" x:Key="txbA">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- ТЕНЬ -->
        <DropShadowEffect x:Key="CardShadow" 
                          Color="#CBD5E1" 
                          Opacity="0.2" 
                          BlurRadius="16" 
                          ShadowDepth="2"
                          Direction="270"/>

        <!-- СТИЛИ КНОПОК -->
        <Style TargetType="Button" x:Key="btnPrimary">
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGrid" x:Key="LargeFontDataGridStyle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HeadersVisibility" Value="All"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="VerticalGridLinesBrush" Value="LightGray"/>
            <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
        </Style>

        <Style TargetType="DataGridColumnHeader" x:Key="DataGridColumnHeaderStyle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="DataGridCellStyle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Arial"/>
        </Style>

        <Style TargetType="Button" x:Key="btnSecondary">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ТЕКСТОВЫЕ ПОЛЯ -->
        <Style TargetType="TextBox" x:Key="ModernTextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox" x:Key="ModernPasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- КОМБОБОКС -->
        <Style TargetType="ComboBox" x:Key="ModernComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="▼" 
                                               FontSize="12"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryColor}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- КАРТОЧКА ТОВАРА (исправленная верстка) -->
        <DataTemplate x:Key="ProductCardTemplate">
            <Border Background="White"
            CornerRadius="12"
            Padding="0"
            Margin="8"
            BorderBrush="{StaticResource BorderLight}"
            BorderThickness="1"
            Width="200"
            Height="260"
            Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>

                    <!-- Изображение -->
                    <Border Grid.Row="0" 
                    Background="#F8FAFC"
                    CornerRadius="12,12,0,0"
                    Padding="10">
                        <Image Source="{Binding ImageUrl}" 
                       Height="100"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                    </Border>

                    <!-- Название товара -->
                    <StackPanel Grid.Row="1" Margin="10,8,10,5">
                        <TextBlock Text="{Binding Name}" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           MaxHeight="40"
                           Foreground="{StaticResource TextColor}"/>
                    </StackPanel>

                    <!-- Цена и кнопка (фиксированная высота) -->
                    <Grid Grid.Row="2" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                           Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentColor}"
                           VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                        Background="{StaticResource AccentGradient}"
                        CornerRadius="8"
                        Width="32" Height="32">
                            <TextBlock Text="+" 
                               FontSize="18" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Статус наличия (фиксированная позиция внизу) -->
                    <Border Grid.Row="3"
                    Background="#F1F5F9"
                    CornerRadius="0,0,12,12"
                    Height="24">
                        <TextBlock Text="В наличии" 
                           FontSize="10"
                           Foreground="{StaticResource SecondaryColor}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Application.Resources>
</Application>
<Page x:Class="NovaCorpSmartHome.Pages.Admin.AdminStock.AdminStockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Admin.AdminStock"
      mc:Ignorable="d" 
      Title="Контроль склада"
      Background="{StaticResource BgColor}"
      Loaded="Page_Loaded">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с заголовком и кнопкой назад -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#10B981"
                        Width="40" Height="40"
                        CornerRadius="10"
                        Margin="0,0,15,0">
                    <TextBlock Text="📦" 
                               FontSize="20"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="КОНТРОЛЬ СКЛАДА"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Управление остатками товаров на складе филиала"
                               FontSize="12"
                               Foreground="#64748B"/>
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="btnBack"
                        Content="← Назад"
                        Style="{StaticResource btnSecondary}"
                        Height="36"
                        Width="80"
                        FontSize="11"
                        Click="btnBack_Click"/>
            </Grid>
        </Border>

        <!-- Панель статистики и фильтров -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статистика -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#10B981"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Всего позиций" FontSize="10" Foreground="#E0F2E0"/>
                            <TextBlock x:Name="txtTotalItems" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F59E0B"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Товаров &lt; 3" FontSize="10" Foreground="#FFF3E0"/>
                            <TextBlock x:Name="txtLowStock" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#EF4444"
                            CornerRadius="8"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Отсутствуют" FontSize="10" Foreground="#FFE5E5"/>
                            <TextBlock x:Name="txtOutOfStock" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Поиск -->
                <Border Grid.Column="2"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Height="36"
                        Width="200"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="🔍" 
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="8,0,4,0"
                                   Foreground="#94A3B8"/>
                        <TextBox x:Name="txtSearch" 
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"
                                 Padding="0,0,8,0"
                                 VerticalAlignment="Center"
                                 TextChanged="txtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Фильтры -->
                <ComboBox x:Name="cmbTypeFilter"
                          Grid.Column="3"
                          Width="100"
                          Height="36"
                          FontSize="11"
                          Margin="0,0,10,0"
                          SelectionChanged="cmbTypeFilter_SelectionChanged">
                    <ComboBoxItem Content="Все типы" IsSelected="True"/>
                    <ComboBoxItem Content="Товар"/>
                    <ComboBoxItem Content="Услуга"/>
                </ComboBox>

                <ComboBox x:Name="cmbStockFilter"
                          Grid.Column="4"
                          Width="120"
                          Height="36"
                          FontSize="11"
                          SelectionChanged="cmbStockFilter_SelectionChanged">
                    <ComboBoxItem Content="Все остатки" IsSelected="True"/>
                    <ComboBoxItem Content="Только в наличии (>0)"/>
                    <ComboBoxItem Content="Малый остаток (≤3)"/>
                    <ComboBoxItem Content="Отсутствуют (0)"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Таблица остатков (улучшенная) -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="0"
                Effect="{StaticResource CardShadow}">
            <DataGrid x:Name="dgStock"
          AutoGenerateColumns="False"
          IsReadOnly="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          FontSize="12"
          HeadersVisibility="Column"
          BorderThickness="0"
          Background="White"
          RowHeight="38"
          AlternatingRowBackground="#F8FAFC"
          BeginningEdit="dgStock_BeginningEdit"
          CellEditEnding="dgStock_CellEditEnding"
          RowEditEnding="dgStock_RowEditEnding">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="36"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>

                    <!-- Стиль для ячеек с цветовой индикацией (как в МойСкладе) -->
                    <Style TargetType="DataGridCell" x:Key="StockCellStyle">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border x:Name="border" 
                                            Background="Transparent" 
                                            BorderBrush="Transparent" 
                                            BorderThickness="0" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                                            <Setter TargetName="border" Property="Background" Value="#FEF2F2"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FECACA"/>
                                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Quantity}" Value="1">
                                            <Setter TargetName="border" Property="Background" Value="#FFF7ED"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FDBA74"/>
                                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Quantity}" Value="2">
                                            <Setter TargetName="border" Property="Background" Value="#FFF7ED"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FDBA74"/>
                                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Quantity}" Value="3">
                                            <Setter TargetName="border" Property="Background" Value="#FFFBEB"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FDE047"/>
                                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Товар с иконкой -->
                    <DataGridTemplateColumn Header="Товар" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="📦" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Product.Name}" 
                                               FontSize="12" 
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Категория -->
                    <DataGridTextColumn Header="Категория" Width="150">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Category.Name" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
                                <Setter Property="TextBlock.Margin" Value="5,0"/>
                                <Setter Property="TextBlock.FontSize" Value="12"/>
                                <Setter Property="TextBlock.Foreground" Value="#64748B"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Тип -->
                    <DataGridTextColumn Header="Тип" Width="70">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Product.Type" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
                                <Setter Property="TextBlock.Margin" Value="5,0"/>
                                <Setter Property="TextBlock.FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Product.Type}" Value="Товар">
                                        <Setter Property="TextBlock.Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Product.Type}" Value="Услуга">
                                        <Setter Property="TextBlock.Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Цена -->
                    <DataGridTextColumn Header="Цена" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Product.Price" StringFormat="{}{0:N0} ₽" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
                                <Setter Property="TextBlock.Margin" Value="5,0"/>
                                <Setter Property="TextBlock.FontSize" Value="12"/>
                                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                                <Setter Property="TextBlock.Foreground" Value="#10B981"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Остаток (редактируемый) -->
                    <DataGridTextColumn Header="Остаток" Width="100" CellStyle="{StaticResource StockCellStyle}">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Quantity" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
                                <Setter Property="TextBlock.Margin" Value="5,0"/>
                                <Setter Property="TextBlock.FontSize" Value="12"/>
                                <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Нижняя панель с подсказками и кнопками действий -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Background="#F0F9FF"
                        CornerRadius="8"
                        Padding="8"
                        Margin="0,0,10,0">
                    <TextBlock Text="ℹ️ Дважды кликните по ячейке «Остаток» для редактирования. Нажмите Enter для сохранения."
                               FontSize="11"
                               Foreground="#2563EB"/>
                </Border>

                <Border Background="#FEF2F2"
                        CornerRadius="8"
                        Padding="8">
                    <TextBlock Text="❗ Цветовая индикация: красный - отсутствует, желтый - мало, зеленый - норма"
                               FontSize="11"
                               Foreground="#EF4444"/>
                </Border>
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="btnRefresh"
                    Content="🔄 Обновить"
                    Style="{StaticResource btnSecondary}"
                    Width="120"
                    Height="36"
                    FontSize="11"
                    Click="btnRefresh_Click"/>
        </Grid>
    </Grid>
</Page>
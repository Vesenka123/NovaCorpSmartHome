<Page x:Class="NovaCorpSmartHome.Pages.Admin.AdminDashboard.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Admin.AdminDashboard"
      mc:Ignorable="d" 
      Title="Панель администратора"
      Background="{StaticResource BgColor}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с приветствием и кнопкой выхода -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="16"
                Padding="20"
                Margin="0,0,0,25"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource AccentColor}"
                        Width="50" Height="50"
                        CornerRadius="12"
                        Margin="0,0,15,0">
                    <TextBlock Text="👨‍💼" 
                               FontSize="24"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Добро пожаловать, Администратор!"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Управляйте системой умного дома через интерактивные карточки"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Кнопка выхода в углу -->
                <Button Grid.Column="2"
                        x:Name="btnLogout"
                        Content="Выйти"
                        Style="{StaticResource btnSecondary}"
                        Background="#FEE2E2"
                        BorderBrush="#EF4444"
                        Foreground="#EF4444"
                        Height="40"
                        Width="70"
                        FontSize="12"
                        Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <!-- Статистика (быстрые цифры) -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Карточка статистики товаров -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource AccentColor}"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="📊" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtProductsCount" 
                                   Text="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Товаров в каталоге" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточка статистики категорий -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#F59E0B"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="📁" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtCategoriesCount" 
                                   Text="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Категорий" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточка статистики остатков -->
            <Border Grid.Column="4"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#10B981"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="📦" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtStockItemsCount" 
                                   Text="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Позиций на складе" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ЗАГОЛОВОК РАЗДЕЛА УПРАВЛЕНИЯ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="{StaticResource AccentColor}"
                    Width="32" Height="32"
                    CornerRadius="8"
                    Margin="0,0,10,0">
                <TextBlock Text="⚙️" 
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="УПРАВЛЕНИЕ СИСТЕМОЙ"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#64748B"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Карточки действий -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center"
                       ItemWidth="320"
                       ItemHeight="160"
                       Orientation="Horizontal">

                <!-- Товары и услуги -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="12"
                        Cursor="Hand"
                        MouseLeftButtonDown="CardProducts_MouseDown"
                        Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Иконка с градиентом -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="{StaticResource AccentGradient}"
                                Width="56" Height="56"
                                CornerRadius="14"
                                Margin="0,0,15,0">
                            <TextBlock Text="🛒" 
                                       FontSize="28"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Товары и услуги"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Справочник устройств"
                                       FontSize="11"
                                       Foreground="#64748B"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Управление каталогом: добавление, редактирование, удаление товаров и услуг умного дома"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>

                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                Background="#F0F9FF"
                                CornerRadius="8"
                                Padding="6,3"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" 
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentColor}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Контроль склада -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="12"
                        Cursor="Hand"
                        MouseLeftButtonDown="CardStock_MouseDown"
                        Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#10B981"
                                Width="56" Height="56"
                                CornerRadius="14"
                                Margin="0,0,15,0">
                            <TextBlock Text="📦" 
                                       FontSize="28"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Контроль склада"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Управление остатками"
                                       FontSize="11"
                                       Foreground="#64748B"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Просмотр и ручное обновление остатков товаров на складе филиала"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>

                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                Background="#D1FAE5"
                                CornerRadius="8"
                                Padding="6,3"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" 
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#10B981"/>
                        </Border>
                    </Grid>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
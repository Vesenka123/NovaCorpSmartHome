<Page x:Class="NovaCorpSmartHome.Pages.Installer.InstallerDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Installer"
      Title="Панель установщика - Новус"
      Background="{StaticResource BgColor}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с приветствием и кнопкой выхода -->
        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="20" Margin="0,0,0,25" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SecondaryColor}" Width="50" Height="50" CornerRadius="12" Margin="0,0,15,0">
                    <TextBlock Text="🛠️" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Добро пожаловать, Установщик!" FontSize="20" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <!-- Обновлено под бренд Новус -->
                    <TextBlock Text="Система управления монтажом «Новус»" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="btnLogout" Content="Выйти" Style="{StaticResource btnSecondary}" Background="#FEE2E2" BorderBrush="#EF4444" Foreground="#EF4444" Height="40" Width="70" FontSize="12" Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <!-- Статистика (быстрые цифры) -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Активные заказы -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource SecondaryColor}" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                        <TextBlock Text="📋" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtActiveCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Активных заказов" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ожидает выезда -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F59E0B" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                        <TextBlock Text="⏳" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtPendingCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Ожидает выезда" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Выполнено за всё время -->
            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="15" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource AccentColor}" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                        <TextBlock Text="✅" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtCompletedCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Выполнено за всё время" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ЗАГОЛОВОК РАЗДЕЛА УПРАВЛЕНИЯ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="{StaticResource SecondaryColor}" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                <TextBlock Text="🔧" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="УПРАВЛЕНИЕ МОНТАЖАМИ" FontSize="14" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Карточки действий -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center" ItemWidth="320" ItemHeight="160" Orientation="Horizontal">

                <!-- Активные заказы -->
                <Border Background="White" CornerRadius="16" Padding="20" Margin="12" Cursor="Hand" MouseLeftButtonDown="CardActiveOrders_MouseDown" Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SecondaryColor}" Width="56" Height="56" CornerRadius="14" Margin="0,0,15,0">
                            <TextBlock Text="📋" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Активные заказы" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Перейти к выполнению" FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Список заказов со статусами «Ожидает установки» и «В работе», назначенных лично вам. Отмечайте начало и завершение работ." FontSize="12" Foreground="#64748B" TextWrapping="Wrap" Margin="0,10,0,10"/>
                        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#D1FAE5" CornerRadius="8" Padding="6,3" HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" FontSize="10" FontWeight="SemiBold" Foreground="#10B981"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- История установок -->
                <Border Background="White" CornerRadius="16" Padding="20" Margin="12" Cursor="Hand" MouseLeftButtonDown="CardHistory_MouseDown" Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Background="#F59E0B" Width="56" Height="56" CornerRadius="14" Margin="0,0,15,0">
                            <TextBlock Text="📅" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="История установок" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Архив выполненных работ" FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Просмотр всех завершенных монтажей с датами выполнения, адресами клиентов и вашими комментариями к заказам." FontSize="12" Foreground="#64748B" TextWrapping="Wrap" Margin="0,10,0,10"/>
                        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FEF3C7" CornerRadius="8" Padding="6,3" HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" FontSize="10" FontWeight="SemiBold" Foreground="#F59E0B"/>
                        </Border>
                    </Grid>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
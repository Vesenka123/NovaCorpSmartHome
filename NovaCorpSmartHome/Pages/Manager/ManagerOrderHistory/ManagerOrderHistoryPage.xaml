<Page x:Class="NovaCorpSmartHome.Pages.Manager.ManagerOrderHistory.ManagerOrderHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Manager.ManagerOrderHistory"
      mc:Ignorable="d" 
      Title="История заказов"
      Background="{StaticResource BgColor}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК С ИКОНКОЙ -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource AccentColor}"
                        Width="40" Height="40"
                        CornerRadius="10"
                        Margin="0,0,15,0">
                    <TextBlock Text="📋" 
                               FontSize="20"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="ИСТОРИЯ ЗАКАЗОВ"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#64748B"/>
                    <TextBlock Text="Просмотр и управление заказами клиента"
                               FontSize="13"
                               Foreground="#1E293B"/>
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="btnBack"
                        Content="← Назад"
                        Style="{StaticResource btnSecondary}"
                        Height="36"
                        Width="80"
                        FontSize="11"
                        Click="btnBack_Click"/>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ПОИСКА -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#F1F5F9"
                        Width="50" Height="50"
                        CornerRadius="10"
                        Margin="0,0,15,0">
                    <TextBlock Text="🔍" 
                               FontSize="24"
                               Foreground="{StaticResource AccentColor}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Номер телефона клиента"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Введите номер в формате +7 (XXX) XXX-XX-XX"
                               FontSize="11"
                               Foreground="#64748B"/>
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Height="45">
                        <TextBox x:Name="txtPhone" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Padding="12,0"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Foreground="#1E293B"/>
                    </Border>

                    <Button Grid.Column="2"
                            x:Name="btnSearch"
                            Content="Найти"
                            Style="{StaticResource btnPrimary}"
                            Height="45"
                            Click="btnSearch_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- СПИСОК ЗАКАЗОВ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: таблица заказов -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource AccentColor}"
                                Width="28" Height="28"
                                CornerRadius="6"
                                Margin="0,0,8,0">
                            <TextBlock Text="📦" 
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ЗАКАЗЫ КЛИЕНТА"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center"/>
                        <Border Background="#E2E8F0"
                                CornerRadius="10"
                                Padding="6,2"
                                Height="20"
                                Margin="8,0,0,0">
                            <TextBlock x:Name="txtOrdersCount" 
                                       Text="0"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#1E293B"/>
                        </Border>
                    </StackPanel>

                    <DataGrid x:Name="dgOrders" 
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              FontSize="12"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeight="36"
                              AlternatingRowBackground="#F8FAFC"
                              SelectionMode="Single"
                              SelectionChanged="dgOrders_SelectionChanged">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Height" Value="32"/>
                                <Setter Property="Padding" Value="8"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="80"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding OrderDate, StringFormat=HH:mm}" Width="60"/>
                            <DataGridTextColumn Header="Статус" Width="90" Binding="{Binding Status}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style>
                                        <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                                        <Setter Property="TextBlock.Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Оформлен">
                                                <Setter Property="TextBlock.Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Оплачен">
                                                <Setter Property="TextBlock.Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" Width="90"/>
                            <DataGridTextColumn Header="Установка" Binding="{Binding InstallationDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Оплата" Binding="{Binding PaymentDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Пустое состояние -->
                    <Border x:Name="gridEmpty"
                            Grid.Row="1"
                            Background="#F8FAFC"
                            CornerRadius="8"
                            Padding="30"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📭" FontSize="48" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Нет заказов" 
                                       FontSize="16"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Введите номер телефона для поиска" 
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Правая колонка: детали заказа и управление -->
            <Border x:Name="borderOrderDetails" 
                    Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="#10B981"
                                Width="28" Height="28"
                                CornerRadius="6"
                                Margin="0,0,8,0">
                            <TextBlock Text="🔍" 
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ЗАКАЗ №"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtOrderId" 
                                   Text=""
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
                    </StackPanel>

                    <!-- Информация о заказе -->
                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Статус:" FontWeight="SemiBold" FontSize="11" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtOrderStatus" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата:" FontWeight="SemiBold" FontSize="11" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtOrderDate" FontSize="11" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Оплата:" FontWeight="SemiBold" FontSize="11" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPaymentDate" FontSize="11"/>
                        </Grid>
                    </Border>

                    <!-- Список товаров -->
                    <TextBlock Grid.Row="2" Text="Состав заказа" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DataGrid x:Name="dgOrderItems" 
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              FontSize="11"
                              HeadersVisibility="Column"
                              BorderThickness="1"
                              BorderBrush="#E2E8F0"
                              RowHeight="28"
                              Margin="0,20,0,12"
                              MaxHeight="150">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Height" Value="28"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Product.Type}" Width="50"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="50"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N0} ₽}" Width="70"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:N0} ₽}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style>
                                        <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                                        <Setter Property="TextBlock.Foreground" Value="{StaticResource AccentColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Итоговая сумма -->
                    <Border Grid.Row="3"
                            Background="#F1F4F9"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ИТОГО:" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="1" x:Name="txtOrderTotal" 
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentColor}"/>
                        </Grid>
                    </Border>

                    <!-- КНОПКА ПОДТВЕРЖДЕНИЯ ОПЛАТЫ -->
                    <Border Grid.Row="4"
                            Background="#F0F9FF"
                            CornerRadius="8"
                            Padding="12"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="💳 Подтверждение оплаты"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentColor}"
                                       Margin="0,0,0,8"/>

                            <Button Grid.Row="1"
                                    x:Name="btnConfirmPayment"
                                    Content="✅ Подтвердить оплату"
                                    Style="{StaticResource btnPrimary}"
                                    Height="40"
                                    FontSize="12"
                                    Click="btnConfirmPayment_Click"
                                    IsEnabled="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Подсказка при отсутствии выбора -->
            <Border x:Name="gridNoSelection"
                    Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="30"
                    Effect="{StaticResource CardShadow}"
                    Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="👈" FontSize="48" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите заказ" 
                               FontSize="16"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Чтобы увидеть состав и управлять статусом" 
                               FontSize="12"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель (статистика) -->
        <Border x:Name="borderStatistics"
                Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,15,0,0"
                Effect="{StaticResource CardShadow}"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtTotalOrders" Text="Всего заказов: 0" FontSize="11" Foreground="#64748B"/>
                </StackPanel>

                <TextBlock Grid.Column="1" 
                           x:Name="txtTotalSum" 
                           Text="Общая сумма: 0 ₽"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentColor}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
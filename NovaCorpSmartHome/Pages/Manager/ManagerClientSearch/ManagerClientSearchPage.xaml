<Page x:Class="NovaCorpSmartHome.Pages.Manager.ManagerClientSearch.ManagerClientSearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Поиск клиента"
      Background="{StaticResource BgColor}">

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      Background="#F8FAFC">
            <Grid Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка: Поиск и создание клиента -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- БЛОК 1: ПОИСК КЛИЕНТА -->
                    <Border Background="White"
                            CornerRadius="16"
                            Padding="30"
                            Margin="0,-30,0,10"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="{StaticResource AccentColor}"
                                        Width="32" Height="32"
                                        CornerRadius="8"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="🔍" 
                                               FontSize="16"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="ПОИСК КЛИЕНТА"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="Найдите существующего клиента по номеру телефона"
                                               FontSize="13"
                                               Foreground="#1E293B"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Поле телефона -->
                            <Grid Grid.Row="1" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="📞" 
                                           FontSize="24"
                                           VerticalAlignment="Center"
                                           Margin="0,0,15,0"/>

                                <Border Grid.Column="1"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Height="50"
                                        Margin="0,0,10,0">
                                    <Grid>
                                        <TextBox x:Name="txtPhone"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontSize="15"
                                                 Padding="15,0"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="#1E293B"
                                                 MaxLength="20"/>
                                    </Grid>
                                </Border>

                                <Button Grid.Column="2"
                                        x:Name="btnSearch"
                                        Content="Найти"
                                        Style="{StaticResource btnPrimary}"
                                        Width="100"
                                        Height="50"
                                        Click="btnSearch_Click"/>
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       Text="Формат: +7 (XXX) XXX-XX-XX или 8XXXXXXXXXX"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       Margin="45,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- БЛОК 2: НОВЫЙ КЛИЕНТ -->
                    <Border Background="White"
                            CornerRadius="16"
                            Padding="30"
                            Margin="0,0,0,0"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <Border Background="#10B981"
                                        Width="32" Height="32"
                                        CornerRadius="8"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="✨" 
                                               FontSize="16"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="НОВЫЙ КЛИЕНТ"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="Заполните информацию для создания нового клиента"
                                               FontSize="13"
                                               Foreground="#1E293B"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="ФИО клиента"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,10"/>

                            <!-- Поля ФИО -->
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Фамилия -->
                                <Border Grid.Column="0" 
                                        Background="#F8FAFC"
                                        CornerRadius="10"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Height="50"
                                        Margin="0,0,5,0">
                                    <Grid>
                                        <TextBlock x:Name="PlaceholderLastName" 
                                                   Text="Фамилия" 
                                                   Foreground="#94A3B8"
                                                   FontSize="14"
                                                   Margin="15,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                        <TextBox x:Name="txtLastName"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontSize="14"
                                                 Padding="15,0"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="#1E293B"
                                                 TextChanged="TextBox_TextChanged"/>
                                    </Grid>
                                </Border>

                                <!-- Имя -->
                                <Border Grid.Column="1" 
                                        Background="#F8FAFC"
                                        CornerRadius="10"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Height="50"
                                        Margin="5,0">
                                    <Grid>
                                        <TextBlock x:Name="PlaceholderFirstName" 
                                                   Text="Имя" 
                                                   Foreground="#94A3B8"
                                                   FontSize="14"
                                                   Margin="15,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                        <TextBox x:Name="txtFirstName"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontSize="14"
                                                 Padding="15,0"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="#1E293B"
                                                 TextChanged="TextBox_TextChanged"/>
                                    </Grid>
                                </Border>

                                <!-- Отчество -->
                                <Border Grid.Column="2" 
                                        Background="#F8FAFC"
                                        CornerRadius="10"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Height="50"
                                        Margin="5,0,0,0">
                                    <Grid>
                                        <TextBlock x:Name="PlaceholderMiddleName" 
                                                   Text="Отчество" 
                                                   Foreground="#94A3B8"
                                                   FontSize="14"
                                                   Margin="15,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                        <TextBox x:Name="txtMiddleName"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontSize="14"
                                                 Padding="15,0"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="#1E293B"
                                                 TextChanged="TextBox_TextChanged"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Адрес и Email -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Адрес -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Адрес"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               Margin="0,0,0,10"/>
                                    <Border Background="#F8FAFC"
                                            CornerRadius="10"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Height="50">
                                        <Grid>
                                            <TextBlock x:Name="PlaceholderAddress" 
                                                       Text="ул. Ленина, д. 15, кв. 42" 
                                                       Foreground="#94A3B8"
                                                       FontSize="14"
                                                       Margin="15,0,0,0"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                            <TextBox x:Name="txtAddress"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FontSize="14"
                                                     Padding="15,0"
                                                     VerticalAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     Foreground="#1E293B"
                                                     TextChanged="TextBox_TextChanged"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Email -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Email (опционально)"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               Margin="0,0,0,10"/>
                                    <Border Background="#F8FAFC"
                                            CornerRadius="10"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Height="50">
                                        <Grid>
                                            <TextBlock x:Name="PlaceholderEmail" 
                                                       Text="client@example.com" 
                                                       Foreground="#94A3B8"
                                                       FontSize="14"
                                                       Margin="15,0,0,0"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                            <TextBox x:Name="txtEmail"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FontSize="14"
                                                     Padding="15,0"
                                                     VerticalAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     Foreground="#1E293B"
                                                     TextChanged="TextBox_TextChanged"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Кнопки -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="1"
                                        x:Name="btnCreateClient"
                                        Content="➕ Создать клиента"
                                        Style="{StaticResource btnPrimary}"
                                        Height="48"
                                        Width="200"
                                        Margin="0,0,10,0"
                                        Click="btnCreateClient_Click"/>

                                <Button Grid.Column="2"
                                        x:Name="btnBack"
                                        Content="← Назад"
                                        Style="{StaticResource btnSecondary}"
                                        Height="48"
                                        Width="120"
                                        Click="btnBack_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Правая колонка: ПОДСКАЗКИ -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="16"
                        Padding="25"
                        Height="310"
                        VerticalAlignment="Top"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#F59E0B"
                                    Width="32" Height="32"
                                    CornerRadius="8"
                                    Margin="0,0,12,0">
                                <TextBlock Text="ℹ️" 
                                           FontSize="16"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Как это работает"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="1️⃣" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Поиск клиента" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                            <TextBlock Text="Введите номер телефона и нажмите 'Найти'"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="22,0,0,10"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="2️⃣" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Создание клиента" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                            <TextBlock Text="Если клиент не найден, заполните ФИО и адрес"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="22,0,0,10"/>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="3️⃣" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Дальнейшие действия" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                            <TextBlock Text="После создания откроется форма оформления заказа"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="22,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
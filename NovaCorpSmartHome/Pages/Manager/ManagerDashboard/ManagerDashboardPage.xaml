<Page x:Class="NovaCorpSmartHome.Pages.Manager.ManagerDashboard.ManagerDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Manager.ManagerDashboard"
      mc:Ignorable="d" 
      Title="Панель менеджера"
      Background="{StaticResource BgColor}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с приветствием и индикацией -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="16"
                Padding="20"
                Margin="0,0,0,25"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#10B981"
                        Width="50" Height="50"
                        CornerRadius="12"
                        Margin="0,0,15,0">
                    <TextBlock Text="👤" 
                               FontSize="24"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Добро пожаловать, "
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"/>
                        <TextBlock x:Name="txtManagerName" 
                                   Text="Менеджер"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#10B981"/>
                    </StackPanel>
                    <TextBlock Text="Рабочее место для обслуживания клиентов и оформления заказов"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Индикатор режима и кнопка выхода -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <Button x:Name="btnLogout"
                            Content="Выйти"
                            Style="{StaticResource btnSecondary}"
                            Background="#FEE2E2"
                            BorderBrush="#EF4444"
                            Foreground="#EF4444"
                            Height="40"
                            Width="70"
                            FontSize="12"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Статистика (быстрые цифры) -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Карточка статистики клиентов сегодня -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#10B981"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="👥" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtClientsCount" 
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Клиентов всего" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточка статистики заказов -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#F59E0B"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="📋" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtOrdersCount" 
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Всего заказов" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточка статистики товаров в наличии -->
            <Border Grid.Column="4"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource AccentColor}"
                            Width="40" Height="40"
                            CornerRadius="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="📦" 
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtStockCount" 
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="Товаров в наличии" 
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ЗАГОЛОВОК РАЗДЕЛА ОПЕРАЦИЙ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="#10B981"
                    Width="32" Height="32"
                    CornerRadius="8"
                    Margin="0,0,10,0">
                <TextBlock Text="⚡" 
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="ОПЕРАЦИИ МЕНЕДЖЕРА"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#64748B"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Карточки действий -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center"
                       ItemWidth="320"
                       ItemHeight="160"
                       Orientation="Horizontal">

                <!-- Поиск клиента -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="12"
                        Cursor="Hand"
                        MouseLeftButtonDown="CardClientSearch_MouseDown"
                        Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#10B981"
                                Width="56" Height="56"
                                CornerRadius="14"
                                Margin="0,0,15,0">
                            <TextBlock Text="🔍" 
                                       FontSize="28"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Поиск клиента"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Работа с клиентами"
                                       FontSize="11"
                                       Foreground="#64748B"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Поиск существующего клиента по номеру телефона или создание нового"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>

                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                Background="#D1FAE5"
                                CornerRadius="8"
                                Padding="6,3"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" 
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#10B981"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- История заказов -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="12"
                        Cursor="Hand"
                        MouseLeftButtonDown="CardOrderHistory_MouseDown"
                        Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#F59E0B"
                                Width="56" Height="56"
                                CornerRadius="14"
                                Margin="0,0,15,0">
                            <TextBlock Text="📋" 
                                       FontSize="28"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="История заказов"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Просмотр заказов"
                                       FontSize="11"
                                       Foreground="#64748B"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Просмотр истории заказов клиента по номеру телефона"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>

                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                Background="#FEF3C7"
                                CornerRadius="8"
                                Padding="6,3"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" 
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#F59E0B"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Каталог (для консультаций) -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="12"
                        Cursor="Hand"
                        MouseLeftButtonDown="CardCatalog_MouseDown"
                        Effect="{StaticResource CardShadow}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1.02" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                                     To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.RenderTransform>
                        <ScaleTransform CenterX="160" CenterY="80"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Background="{StaticResource AccentColor}"
                                Width="56" Height="56"
                                CornerRadius="14"
                                Margin="0,0,15,0">
                            <TextBlock Text="📦" 
                                       FontSize="28"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Каталог товаров"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Для консультации клиентов"
                                       FontSize="11"
                                       Foreground="#64748B"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Просмотр каталога устройств и услуг умного дома (режим консультации)"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>

                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                Background="#F0F9FF"
                                CornerRadius="8"
                                Padding="6,3"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Перейти →" 
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentColor}"/>
                        </Border>
                    </Grid>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
<Page x:Class="NovaCorpSmartHome.Pages.Authorization.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="AuthorizationPage"
      Background="{StaticResource BgColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Карточка -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="24"
                Margin="0,40"
                Effect="{StaticResource CardShadow}">
            <StackPanel Margin="32">

                <!-- Логотип -->
                <Border Width="64" Height="64"
                        CornerRadius="10"
                        ClipToBounds="True"
                        Margin="0,0,0,20">
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="10" 
                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}" 
                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                    <Image Source="/Resources/logo.png"/>
                </Border>

                <TextBlock Text="Добро пожаловать!"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextColor}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Войдите в систему для продолжения"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryColor}"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,30"/>

                <!-- Логин -->
                <TextBlock Text="Логин"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryColor}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin"
                         Height="40"
                         FontSize="14"
                         Background="#F8FAFC"
                         BorderBrush="{StaticResource BorderLight}"
                         BorderThickness="1"
                         Padding="12,8"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryColor}"
                           Margin="0,15,0,5"/>
                <PasswordBox x:Name="txtPassword"
                             Height="40"
                             FontSize="14"
                             Background="#F8FAFC"
                             BorderBrush="{StaticResource BorderLight}"
                             BorderThickness="1"
                             Padding="12,8"/>

                <!-- Кнопка входа -->
                <Button x:Name="btnLogin"
                        Content="Войти в систему"
                        Height="44"
                        Margin="0,20,0,10"
                        Click="btnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource AccentColor}"
                                    CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <!-- Разделитель -->
                <Grid Margin="0,20,0,20">
                    <Line X1="0" Y1="0" X2="1" Y2="0"
                          Stretch="Fill"
                          Stroke="{StaticResource BorderLight}"
                          StrokeThickness="1"
                          VerticalAlignment="Center"/>
                </Grid>

                <!-- Гость -->
                <Button Content="Продолжить как гость"
                        Height="44"
                        Click="btnGuest_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="{StaticResource BorderLight}"
                                    BorderThickness="1.5"
                                    CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
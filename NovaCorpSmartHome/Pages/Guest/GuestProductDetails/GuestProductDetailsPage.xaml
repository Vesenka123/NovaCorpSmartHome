<Page x:Class="NovaCorpSmartHome.Pages.Guest.GuestProductDetails.GuestProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NovaCorpSmartHome.Pages.Guest.GuestProductDetails"
      mc:Ignorable="d" 
      Title="Детали товара"
      Background="{StaticResource BgColor}">

    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Изображение -->
        <Border Grid.Column="0"
                Background="#F8FAFC"
                CornerRadius="16"
                Padding="20"
                Height="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Image x:Name="imgProduct"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Border>

        <!-- Описание -->
        <StackPanel Grid.Column="1" Margin="32,0,0,0">
            <TextBlock x:Name="txtName"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextColor}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="txtType"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryColor}"
                       Margin="0,0,0,15"/>

            <TextBlock x:Name="txtPrice"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentColor}"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="txtDescription"
                       FontSize="16"
                       HorizontalAlignment="Left"
                       Foreground="{StaticResource TextColor}"
                       TextWrapping="Wrap"
                       MaxWidth="600"/>

            <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                <Button Content="Назад к каталогу"
                        Style="{StaticResource btnSecondary}"
                        Click="btnBack_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
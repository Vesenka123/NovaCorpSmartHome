<Page x:Class="NovaCorpSmartHome.Pages.Guest.GuestCatalog.GuestCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Каталог умного дома"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" 
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>



                <!-- ПОИСК -->
                <Border Grid.Column="1" 
                        Background="#F5F5F5"
                        Height="40"
                        Width="500"
                        HorizontalAlignment="Center"
                        CornerRadius="20"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="🔍" 
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="15,0,0,0"
                                   Foreground="#9CA3AF"/>

                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalAlignment="Center"
                                 TextChanged="txtSearch_TextChanged"
                                 Foreground="#1E293B"/>

                        <Button x:Name="btnClearSearch"
                                Grid.Column="2"
                                Width="30" Height="30"
                                Margin="0,0,10,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="btnClearSearch_Click"
                                Visibility="Collapsed"
                                Cursor="Hand">
                            <TextBlock Text="✕" 
                                       Foreground="#9CA3AF"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- КНОПКА ВХОДА -->
                <Button Grid.Column="2" 
                        x:Name="btnAuthorization"
                        Click="btnAuthorization_Click"
                        Width="120" Height="40"
                        Background="#2563EB"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="20">
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="👤" 
                                               FontSize="16"
                                               Foreground="White"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Войти" 
                                               Foreground="White"
                                               FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <Border Grid.Column="0" 
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ЗАГОЛОВОК КАТЕГОРИЙ -->
                    <Border Grid.Row="0"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="15,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="КАТЕГОРИИ"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#666666"
                                       VerticalAlignment="Center"/>

                        </Grid>
                    </Border>

                    <!-- ДЕРЕВО КАТЕГОРИЙ -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Background="White">
                        <TreeView x:Name="tvCategories" 
                                  SelectedItemChanged="tvCategories_SelectedItemChanged"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="0,5,0,20">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="15,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>

                    <!-- ИНФОРМАЦИЯ О ФИЛИАЛЕ -->
                    <Border Grid.Row="2"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,1,0,0"
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="НАШ ФИЛИАЛ"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#666666"
                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📍" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="г. Хабаровск, ул. Ленина, 15" 
                                           FontSize="12"
                                           Foreground="#1E293B"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📞" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="+7 (4212) 12-34-56" 
                                           FontSize="12"
                                           Foreground="#2563EB"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🕒" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="Пн-Пт: 9:00-19:00, Сб: 10:00-17:00" 
                                           FontSize="11"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ -->
            <Grid Grid.Column="1" Background="#F5F5F5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ВЕРХНЯЯ ПАНЕЛЬ С НАВИГАЦИЕЙ -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="20,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ХЛЕБНЫЕ КРОШКИ -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="txtHome" 
                                       Text="Главная" 
                                       Foreground="#2563EB"
                                       FontSize="13"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="Home_Click"/>

                            <ItemsControl x:Name="icBreadcrumbs" Margin="0,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="/" 
                                                       Foreground="#999999"
                                                       Margin="8,0"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       Foreground="#1E293B"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Cursor="Hand"
                                                       MouseLeftButtonDown="Breadcrumb_Click"
                                                       Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- КОЛИЧЕСТВО И СОРТИРОВКА -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock x:Name="txtProductsCount" 
                                       Text="0 товаров"
                                       FontSize="13"
                                       Foreground="#666666"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>

                            <ComboBox x:Name="cmbSort"
                                      Width="160" 
                                      Height="25"
                                      FontSize="13"
                                      SelectionChanged="cmbSort_SelectionChanged"
                                      Background="White"
                                      BorderBrush="#E0E0E0"
                                      BorderThickness="1">
                                <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                                <ComboBoxItem Content="Сначала дешевле"/>
                                <ComboBoxItem Content="Сначала дороже"/>
                                <ComboBoxItem Content="По названию"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ТОВАРЫ -->
                <Grid Grid.Row="1">
                    <Grid x:Name="gridLoading" 
                          Background="#FFFFFF80"
                          Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="48" Foreground="#2563EB"/>
                            <TextBlock Text="Загрузка..." 
                                       FontSize="14"
                                       Foreground="#666666"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="scrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20">
                        <ItemsControl x:Name="icProducts">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- КАРТОЧКА ТОВАРА ИСПРАВЛЕННАЯ -->
                                    <Border Background="White"
                                            CornerRadius="8"
                                            Margin="8"
                                            Width="175"
                                            Height="260"
                                            MouseDown="ProductCard_MouseDown"
                                            BorderBrush="#E0E0E0"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#CCCCCC" 
                                                             Opacity="0.1" 
                                                             BlurRadius="8" 
                                                             ShadowDepth="2"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="130"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="40"/>
                                                <RowDefinition Height="28"/>
                                            </Grid.RowDefinitions>

                                            <!-- ФОТО ТОВАРА -->
                                            <Border Grid.Row="0" 
                                                    Background="#F8F8F8"
                                                    CornerRadius="8,8,0,0"
                                                    Padding="15">
                                                <Image Source="{Binding ImageUrl}" 
                                                       Height="100"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- НАЗВАНИЕ И ТИП -->
                                            <StackPanel Grid.Row="1" Margin="12,8,12,0">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="13" 
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="36"
                                                           Foreground="#1E293B"/>

                                                <TextBlock Text="{Binding Type}" 
                                                           FontSize="11"
                                                           Foreground="#999999"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- ЦЕНА -->
                                            <TextBlock Grid.Row="2"
                                                       Margin="12,0,0,0"
                                                       Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                                       FontSize="18" 
                                                       FontWeight="Bold"
                                                       Foreground="#2563EB"
                                                       VerticalAlignment="Center"/>

                                            <!-- СТАТУС (ВСЕГДА ВНИЗУ) -->
                                            <Border Grid.Row="3"
                                                    Background="#F0F9FF"
                                                    CornerRadius="0,0,8,8"
                                                    Height="28">
                                                <TextBlock Text="✓ В наличии" 
                                                           FontSize="11"
                                                           Foreground="#2563EB"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid x:Name="gridEmpty" 
                          Background="Transparent"
                          Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="64" Foreground="#CCCCCC"/>
                            <TextBlock Text="Товары не найдены" 
                                       FontSize="18"
                                       Foreground="#666666"
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="Попробуйте изменить параметры поиска" 
                                       FontSize="13"
                                       Foreground="#999999"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>